# ── Required ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://forge:forge@localhost:5432/forge
RPC_URL_1=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_URL_8453=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Optional — forge-index configuration ─────────────────────────────
FORGE_ENV=prod                 # dev | prod
FORGE_PORT=42069               # HTTP server port
FORGE_SCHEMA=public            # Postgres schema name
FORGE_LOG_LEVEL=info           # trace | debug | info | warn | error
FORGE_API_KEY=                 # Bearer token for /sql in prod mode (optional)
FORGE_RPC_RATE_LIMIT=25        # RPC requests per second per chain

# ── Postgres (for docker-compose) ────────────────────────────────────
POSTGRES_DB=forge
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge

# ── Grafana (for docker-compose) ─────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=admin
